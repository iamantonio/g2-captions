{
  "name": "g2-captions",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build": "tsc && vite build",
    "dev": "vite --host 127.0.0.1",
    "prototype": "tsx tools/run-fixture-prototype.ts",
    "benchmark:fixtures": "tsx tools/run-fixture-benchmark.ts",
    "hardware:readiness": "tsx tools/run-hardware-readiness.ts",
    "token-broker": "tsx tools/token-broker.ts",
    "clean": "rm -rf dist artifacts coverage && rm -f *.ehpk",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:coverage": "vitest run --coverage",
    "audit:ci": "audit-ci --moderate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "pino": "^10.3.1",
    "rate-limiter-flexible": "^11.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "audit-ci": "^7.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "superwstest": "^3.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  }
}
