# Local-only token broker configuration.
# Copy this file to .env or export the values in your shell.
# Never commit real API keys.

# AssemblyAI streaming API key. Required only when using the AssemblyAI
# vendor seam (see /assemblyai/token route).
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Deepgram streaming API key. Required for the default Deepgram vendor seam
# (used by /deepgram/token and the /deepgram/listen WebSocket proxy).
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Optional: override the broker port. Defaults to 8787.
# TOKEN_BROKER_PORT=8787

# Optional: override the broker bind host. Defaults to 127.0.0.1 (loopback).
# Set to 0.0.0.0 only for the documented G2 hardware-smoke flow.
# TOKEN_BROKER_HOST=127.0.0.1
